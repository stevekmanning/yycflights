# SerpApi — https://serpapi.com
# Sign up free → Dashboard → API Key
SERPAPI_KEY=your_api_key_here

# Resend — https://resend.com (free: 3,000 emails/month, no domain needed to start)
# Sign up → API Keys → Create API Key
RESEND_API_KEY=your_resend_api_key
# From address — use a verified domain, or leave blank for onboarding@resend.dev (testing only)
ALERT_FROM=YYC Flights <you@yourdomain.com>

# Server config
PORT=3000
ORIGIN=YYC

# Cron schedule — every 12h = ~60 searches/month per alert (within SerpApi free tier)
CRON_SCHEDULE=0 */12 * * *
